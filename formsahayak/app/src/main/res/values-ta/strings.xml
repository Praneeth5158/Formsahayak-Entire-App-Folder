    <!-- How To Use -->
    <string name="how_to_use">எப்படி பயன்படுத்துவது</string>
    <string name="htu_welcome">FormSahayak-க்கு வரவேற்கிறோம்!</string>
    <string name="htu_subtitle">உங்கள் வங்கி படிவங்களை எளிதாக நிரப்ப இந்த எளிய வழிமுறைகளை பின்பற்றவும்</string>
    <string name="htu_video_title">வீடியோ டுடோரியல்</string>
    <string name="htu_video_desc">FormSahayak ஐ எவ்வாறு பயன்படுத்துவது என்பதை அறிய இந்த பயனுள்ள வீடியோ வழிகாட்டியைப் பார்க்கவும்.</string>
    <string name="htu_video_tap">முழு வீடியோ டுடோரியலைப் பார்க்க தட்டவும்</string>
    <string name="htu_step1_title">படிவப் படத்தைப் பதிவேற்றவும்</string>
    <string name="htu_step1_desc">உங்கள் வங்கி படிவத்தின் புகைப்படத்தை எடுக்கவும் அல்லது கேலரியில் இருந்து பதிவேற்றவும். படம் தெளிவாகவும் வெளிச்சமாகவும் இருப்பதை உறுதி செய்யவும்.</string>
    <string name="htu_step2_title">ஆப் புலங்களைக் கண்டறியும்</string>
    <string name="htu_step2_desc">FormSahayak நீங்கள் படிவத்தில் நிரப்ப வேண்டிய அனைத்து புலங்களையும் தானாகவே கண்டறிந்து முன்னிலைப்படுத்தும்.</string>
    <string name="htu_step3_title">குரல் வழிமுறைகளைப் பின்பற்றவும்</string>
    <string name="htu_step3_desc">ஒவ்வொரு புலத்திலும் என்ன எழுத வேண்டும் என்பதை விளக்கும் உங்கள் மொழியில் குரல் வழிகாட்டுதலைக் கேளுங்கள்.</string>
    <string name="htu_step4_title">படிவத்தை சரியாக நிரப்பவும்</string>
    <string name="htu_step4_desc">அனைத்து புலங்களையும் துல்லியமாக நிரப்பவும் உங்கள் வங்கி படிவத்தை பூர்த்தி செய்யவும் பயன்பாட்டின் வழிகாட்டுதலைப் பயன்படுத்தவும்.</string>
    <string name="htu_need_help">மேலும் உதவி வேண்டுமா?</string>
    <string name="htu_contact_support">உதவிக்கு எங்கள் ஆதரவு குழுவை தொடர்பு கொள்ளவும்</string>
    <string name="htu_share_exp">உங்கள் அனுபவத்தைப் பகிரவும்</string>
    <string name="htu_share_desc">உங்கள் மதிப்புமிக்க கருத்துக்களுடன் FormSahayak ஐ மேம்படுத்த எங்களுக்கு உதவுங்கள்.</string>
